generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CatalogStatus {
  Approved
  Pending
  Rejected
}

enum CollectionCondition {
  Mint
  NearMint
  Good
  Damaged
}

enum CollectionStatus {
  Holding
  Sold
  Wishlist
  Lost
}

enum CollectionEventType {
  AddedCollection
  PriceUpdated
  StatusChanged
  Sold
  Deleted
  InfoEdited
}

enum PosterTemplateKey {
  Minimal
  CutePink
  CollectionCard
  Vintage
}

model User {
  id           String @id @default(cuid())
  username     String @unique
  passwordHash String
  nickname     String?
  avatarUrl    String?
  bio          String?

  setting      UserSetting?
  catalogItems CatalogItem[] @relation("CatalogCreator")
  collections  CollectionItem[]
  priceRecords PriceRecord[]
  events       CollectionEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserSetting {
  id                      String @id @default(cuid())
  userId                  String @unique
  user                    User @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency                String @default("CNY")
  defaultPosterTemplateId String?
  defaultPosterTemplate   PosterTemplate? @relation(fields: [defaultPosterTemplateId], references: [id])
  showPurchasePrice       Boolean @default(false)
  showFloatAmount         Boolean @default(true)
  showSeriesInfo          Boolean @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model CatalogItem {
  id            String @id @default(cuid())
  name          String
  characterName String
  series        String?
  model         String?
  releaseDate   DateTime?
  officialPrice Decimal? @db.Decimal(12, 2)
  coverImage    String?
  tags          String[] @default([])
  description   String?
  status        CatalogStatus @default(Approved)
  createdById   String
  createdBy     User @relation("CatalogCreator", fields: [createdById], references: [id])

  images       CatalogImage[]
  collections  CollectionItem[]
  priceRecords PriceRecord[]
  events       CollectionEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([characterName])
  @@index([series])
  @@index([status])
}

model CatalogImage {
  id            String @id @default(cuid())
  catalogItemId String
  catalogItem   CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  url           String
  objectKey     String
  provider      String @default("aliyun-oss")
  mimeType      String?
  size          Int?
  sortOrder     Int @default(0)
  createdAt     DateTime @default(now())

  @@index([catalogItemId])
}

model CollectionItem {
  id              String @id @default(cuid())
  userId          String
  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)
  catalogItemId   String
  catalogItem     CatalogItem @relation(fields: [catalogItemId], references: [id])
  purchasePrice   Decimal? @db.Decimal(12, 2)
  purchaseDate    DateTime?
  purchaseChannel String?
  condition       CollectionCondition @default(Mint)
  status          CollectionStatus @default(Holding)
  estimatedPrice  Decimal? @db.Decimal(12, 2)
  note            String?

  images CollectionImage[]
  events CollectionEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([catalogItemId])
  @@index([purchaseDate])
}

model CollectionImage {
  id               String @id @default(cuid())
  collectionItemId String
  collectionItem   CollectionItem @relation(fields: [collectionItemId], references: [id], onDelete: Cascade)
  url              String
  objectKey        String
  provider         String @default("aliyun-oss")
  mimeType         String?
  size             Int?
  sortOrder        Int @default(0)
  createdAt        DateTime @default(now())

  @@index([collectionItemId])
}

model PriceRecord {
  id            String @id @default(cuid())
  catalogItemId String
  catalogItem   CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  userId        String?
  user          User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  price         Decimal @db.Decimal(12, 2)
  recordDate    DateTime @default(now())
  source        String?
  note          String?
  createdAt     DateTime @default(now())

  @@index([catalogItemId, recordDate])
  @@index([userId])
}

model CollectionEvent {
  id               String @id @default(cuid())
  userId           String
  user             User @relation(fields: [userId], references: [id], onDelete: Cascade)
  catalogItemId    String?
  catalogItem      CatalogItem? @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)
  collectionItemId String?
  collectionItem   CollectionItem? @relation(fields: [collectionItemId], references: [id], onDelete: SetNull)
  type             CollectionEventType
  title            String
  snapshot         Json?
  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
  @@index([collectionItemId])
}

model PosterTemplate {
  id           String @id @default(cuid())
  key          PosterTemplateKey @unique
  name         String
  description  String?
  previewImage String?
  config       Json?
  isActive     Boolean @default(true)
  settings     UserSetting[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
