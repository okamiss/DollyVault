{
  "name": "dollyvault",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "dev": "pnpm --parallel --filter @dollyvault/api --filter @dollyvault/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "prisma:generate": "pnpm --filter @dollyvault/api prisma:generate",
    "prisma:migrate": "pnpm --filter @dollyvault/api prisma:migrate",
    "seed": "pnpm --filter @dollyvault/api seed"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
